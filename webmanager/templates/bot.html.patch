     function force_reports() {
         $("#btn-force-reports").prop("disabled", true).text("Starting...");
         $.ajax({
             url: '/api/force_reports',
             type: 'POST',
             success: function (r) {
                 alert(r.message);
                 $("#btn-force-reports").text("✅ Triggered");
             },
             error: function (e) {
                 alert("Error: " + e.responseJSON.message);
                 $("#btn-force-reports").prop("disabled", false).text("🔄 Fetch Historic Reports");
             }
         });
     }
 
+    function clear_reports() {
+        if (!confirm("Are you sure? This deletes local report cache & triggers re-download.")) return;
+        $("#btn-clear-reports").prop("disabled", true).text("Clearing...");
+        $.ajax({
+            url: '/api/clear_reports',
+            type: 'POST',
+            success: function (r) {
+                alert(r.message);
+                $("#btn-clear-reports").text("✅ Cleared & Triggered");
+            },
+            error: function (e) {
+                alert("Error: " + e.responseJSON.message);
+                $("#btn-clear-reports").prop("disabled", false).text("⚠️ Reload All Reports (Clear DB)");
+            }
+        });
+    }

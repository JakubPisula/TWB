{
  "manifest_version": 3,
  "name": "TWB Cookie Sync",
  "version": "1.0",
  "description": "Automatically sends Tribal Wars / Plemiona session cookies to your local TWB bot server so you never have to paste them manually.",
  "permissions": [
    "cookies",
    "alarms",
    "storage",
    "notifications",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.plemiona.pl/*",
    "https://*.tribalwars.net/*",
    "https://*.die-staemme.de/*",
    "https://*.tribalwars.nl/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.plemiona.pl/game.php*screen=report*",
        "*://*.tribalwars.net/game.php*screen=report*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
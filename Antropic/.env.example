# ─────────────────────────────────────────────────────────────────────────────
# .env.local  –  Freelancer Web Panel
# Skopiuj do .env.local i uzupełnij wartości. NIE commituj do repozytorium.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=wygeneruj-losowy-string-min-32-znaki

# ── Prisma / PostgreSQL ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/freelancer_panel"

# ── Notion ────────────────────────────────────────────────────────────────────
# Token z https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID baz danych (32-znakowy hash z URL bazy w Notion)
# URL: https://www.notion.so/workspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
NOTION_DB_KLIENCI=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_ZADANIA=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Wybierz: "google" lub "nextcloud"
CLOUD_PROVIDER=google

# Google Drive (Service Account)
# Klucz JSON z Google Cloud Console → IAM → Service Accounts → Create Key
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# Skopiuj wartość "private_key" z JSON (zachowaj \n jako separator linii)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIB...\n-----END PRIVATE KEY-----\n"
# Opcjonalnie: ID folderu nadrzędnego na Drive
GOOGLE_DRIVE_PARENT_FOLDER=

# Nextcloud (WebDAV) – alternatywa dla Google Drive
NEXTCLOUD_BASE_URL=https://cloud.twojastrona.pl
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=haslo
NEXTCLOUD_BASE_PATH=/remote.php/dav/files/admin/Projekty_Freelancer

# ── Adobe Premiere API ────────────────────────────────────────────────────────
# Dowolny długi, losowy string. Wtyczka Adobe musi go znać.
ADOBE_API_SECRET=wygeneruj-losowy-tajny-klucz-dla-adobe
